{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yumetsuki.local/schemas/release_manifest.schema.json",
  "title": "Yumetsuki release manifest",
  "type": "object",
  "required": [
    "app_version",
    "schema_hash",
    "generated_at",
    "target_triple",
    "build_profile",
    "build_inputs",
    "lockfiles",
    "artifacts",
    "artifact_hashes",
    "size_bytes",
    "budgets",
    "approval_records"
  ],
  "additionalProperties": false,
  "properties": {
    "app_version": { "type": "string", "minLength": 1 },
    "schema_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "generated_at": { "type": "string", "minLength": 1 },
    "target_triple": { "type": "string", "minLength": 1 },
    "build_profile": { "const": "release" },
    "build_inputs": {
      "type": "object",
      "required": [
        "git_commit",
        "source_tree_status",
        "python_version",
        "node_version",
        "rust_version",
        "tauri_version",
        "requirements_sidecar_hash",
        "node_lock_hash",
        "cargo_lock_hash",
        "capability_manifest_hash"
      ],
      "additionalProperties": true,
      "properties": {
        "git_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "source_tree_status": { "type": "string", "enum": ["clean", "dirty"] },
        "python_version": { "type": "string", "minLength": 1 },
        "node_version": { "type": "string", "minLength": 1 },
        "rust_version": { "type": "string", "minLength": 1 },
        "tauri_version": { "type": "string", "minLength": 1 },
        "requirements_sidecar_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "node_lock_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "cargo_lock_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "capability_manifest_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
      }
    },
    "lockfiles": {
      "type": "array",
      "items": { "$ref": "#/$defs/file_record" }
    },
    "artifacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/file_record" }
    },
    "artifact_hashes": {
      "type": "object",
      "required": ["sidecar", "frontend_dist", "capability_manifest"],
      "additionalProperties": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
      "properties": {
        "sidecar": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "frontend_dist": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "capability_manifest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
      }
    },
    "size_bytes": {
      "type": "object",
      "required": ["bundle", "sidecar", "frontend", "resources", "installer"],
      "additionalProperties": { "type": "integer", "minimum": 1 },
      "properties": {
        "bundle": { "type": "integer", "minimum": 1 },
        "sidecar": { "type": "integer", "minimum": 1 },
        "frontend": { "type": "integer", "minimum": 1 },
        "resources": { "type": "integer", "minimum": 1 },
        "installer": { "type": "integer", "minimum": 1 }
      }
    },
    "budgets": {
      "type": "object",
      "required": ["bundle_size_bytes", "sidecar_size_bytes", "frontend_size_bytes"],
      "additionalProperties": { "type": "integer", "minimum": 1 },
      "properties": {
        "bundle_size_bytes": { "type": "integer", "minimum": 1 },
        "sidecar_size_bytes": { "type": "integer", "minimum": 1 },
        "frontend_size_bytes": { "type": "integer", "minimum": 1 }
      }
    },
    "approval_records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["scope", "reason", "approved_by", "approved_at"],
        "additionalProperties": false,
        "properties": {
          "scope": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 },
          "approved_by": {
            "type": "string",
            "minLength": 1,
            "not": { "pattern": "([Tt][Oo][Kk][Ee][Nn]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Cc][Oo][Oo][Kk][Ii][Ee]|[Aa][Uu][Tt][Hh][Oo][Rr][Ii][Zz][Aa][Tt][Ii][Oo][Nn])" }
          },
          "approved_at": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$defs": {
    "file_record": {
      "type": "object",
      "required": ["path", "sha256", "size_bytes"],
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "size_bytes": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
