{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Yumetsuki",
  "version": "0.1.0",
  "identifier": "dev.yumetsuki.desktop",
  "build": {
    "beforeDevCommand": "pnpm --dir frontend dev",
    "beforeBuildCommand": "pnpm --dir frontend build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Yumetsuki",
        "width": 1100,
        "height": 760,
        "minWidth": 840,
        "minHeight": 560
      },
      {
        "label": "pet",
        "title": "Yumetsuki Pet",
        "width": 420,
        "height": 520,
        "visible": false,
        "transparent": true,
        "decorations": false
      },
      {
        "label": "settings",
        "title": "Yumetsuki Settings",
        "width": 980,
        "height": 720,
        "visible": false
      },
      {
        "label": "diagnostics",
        "title": "Yumetsuki Diagnostics",
        "width": 980,
        "height": 720,
        "visible": false
      }
    ],
    "security": {
      "capabilities": ["main", "pet", "settings", "diagnostics"],
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
