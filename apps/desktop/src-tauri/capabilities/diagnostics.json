{
  "identifier": "diagnostics",
  "windows": ["diagnostics"],
  "commands": [
    "sidecar_health",
    "diagnostics_run",
    "diagnostics_export",
    "logs_query",
    "logs_export"
  ],
  "permissions": [],
  "security": {
