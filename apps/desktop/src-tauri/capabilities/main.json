{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main",
  "description": "主窗口 capability：sidecar 生命周期、脱敏配置、脱敏日志、聊天、诊断、工具、插件、MCP 和安全摘要入口。",
  "windows": ["main"],
  "permissions": [
    "core:app:default",
    "core:event:default",
    "core:window:default",
    "sidecar-lifecycle",
    "config-read",
    "logs-read",
    "chat-core",
    "diagnostics-run",
    "tools-bridge",
    "plugins-bridge",
    "mcp-bridge",
    "security-grants"
  ]
}
